<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Pomodoro" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorPrimaryVariant">@color/primary_color</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/surface_color</item>
        <item name="colorOnSecondary">@color/accent_color</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/accent_color</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/surface_color</item>
        <item name="bottomNavigationStyle">@style/BottomNavStyle</item>
    </style>

    <style name="Theme.Pomodoro.Dark" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorPrimaryVariant">@color/primary_color</item>
        <item name="colorOnPrimary">@color/accent_color</item>
        <item name="colorSecondary">@color/accent_color</item>
        <item name="colorSurface">@color/dark_bg</item>
        <item name="colorOnSurface">@color/surface_color</item>
        <item name="android:windowBackground">@color/dark_bg</item>
        <item name="android:statusBarColor">@color/dark_bg</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Thème du Splash : fond blanc, pas d'ActionBar, barre de statut blanche -->
    <style name="Theme.Pomodoro.Splash" parent="Theme.Pomodoro">
        <item name="android:windowBackground">@color/white</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="BottomNavStyle" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="elevation">8dp</item>
    </style>
</resources>
